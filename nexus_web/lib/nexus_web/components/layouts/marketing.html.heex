<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <title>EQUINOX | Corporate Treasury Intelligence</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500&family=Playfair+Display:ital,wght@0,500;0,600;0,700;1,500;1,600;1,700;1,800;1,900&display=swap"
      rel="stylesheet"
    />
    <script src="https://unpkg.com/three@0.128.0/build/three.min.js">
    </script>
    <script src="https://cdn.tailwindcss.com">
    </script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js">
    </script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js">
    </script>
    <script src="https://unpkg.com/lucide@latest">
    </script>
    <script>
      tailwind.config = {
        theme: {
          extend: {
            colors: {
              obsidian: '#030303',
              emerald: { 400: '#34d399', 500: '#10b981', 600: '#059669' },
              zinc: { 950: '#09090b' }
            },
            fontFamily: {
              sans: ['Inter', 'sans-serif'],
              serif: ['Playfair Display', 'serif'],
              mono: ['JetBrains Mono', 'monospace'],
            }
          }
        }
      }
    </script>
    <style>
      * { cursor: none; }
      @media (max-width: 1024px) {
        * { cursor: auto; }
        #cursor-dot, #cursor-ring { display: none; }
      }
      body { background-color: #030303; color: white; overflow-x: hidden; }
      .bg-grid {
        background-size: 60px 60px;
        background-image:
          linear-gradient(to right, rgba(52, 211, 153, 0.05) 1px, transparent 1px),
          linear-gradient(to bottom, rgba(52, 211, 153, 0.05) 1px, transparent 1px);
        mask-image: radial-gradient(circle at center, black, transparent 80%);
      }
      .noise-overlay {
        position: fixed; top: 0; left: 0; width: 100%; height: 100%;
        pointer-events: none; opacity: 0.04; z-index: 9999;
        background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E");
      }
      #cursor-dot { width: 6px; height: 6px; background: #34d399; border-radius: 50%; position: fixed; pointer-events: none; z-index: 10000; transform: translate(-50%, -50%); transition: transform 0.2s ease; }
      #cursor-ring { width: 36px; height: 36px; border: 1px solid rgba(52, 211, 153, 0.4); border-radius: 50%; position: fixed; pointer-events: none; z-index: 9999; transform: translate(-50%, -50%); transition: width 0.2s, height 0.2s, border-color 0.2s; }
      @keyframes marquee { 0% { transform: translateX(0); } 100% { transform: translateX(-50%); } }
      .animate-marquee { animation: marquee 30s linear infinite; }
      .animate-marquee:hover { animation-play-state: paused; }
      nav { transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1); }
      nav.scrolled { width: 100% !important; border-radius: 0 !important; background: rgba(3, 3, 3, 0.92); backdrop-filter: blur(20px); border-bottom: 1px solid rgba(52, 211, 153, 0.2); margin-top: 0 !important; }
      .nav-link { position: relative; }
      .nav-link::after { content: ''; position: absolute; bottom: -4px; left: 0; width: 0; height: 1px; background: #34d399; transition: width 0.3s ease; }
      .nav-link:hover::after { width: 100%; }
      .glass-nav { background: rgba(24, 24, 27, 0.6); backdrop-filter: blur(16px); border: 1px solid rgba(255, 255, 255, 0.08); }
      .hero-title { font-size: clamp(3rem, 9vw, 8rem); line-height: 0.92; }
      ::-webkit-scrollbar { width: 5px; }
      ::-webkit-scrollbar-track { background: #030303; }
      ::-webkit-scrollbar-thumb { background: #34d399; border-radius: 10px; }
      .accordion-content { max-height: 0; overflow: hidden; transition: max-height 0.5s cubic-bezier(0.4, 0, 0.2, 1); }
      .accordion-content.active { max-height: 500px; }
      .globe-wrapper { position: relative; border-radius: 32px; overflow: hidden; background: radial-gradient(circle at 30% 20%, rgba(52,211,153,0.08), transparent 70%); }
      .globe-glow-overlay { position: absolute; inset: 0; pointer-events: none; border-radius: 32px; box-shadow: inset 0 0 80px rgba(52,211,153,0.08), 0 0 60px rgba(52,211,153,0.1); z-index: 10; }
      .tx-notification { position: absolute; background: rgba(9, 9, 11, 0.9); backdrop-filter: blur(16px); border: 1px solid rgba(52, 211, 153, 0.4); border-radius: 12px; padding: 12px 18px; min-width: 220px; z-index: 50; pointer-events: none; box-shadow: 0 10px 40px rgba(0,0,0,0.8), 0 0 25px rgba(52,211,153,0.1); }
      .pulse-ring { box-shadow: 0 0 0 0 rgba(52, 211, 153, 0.5); animation: pulse-ring 2s infinite; }
      @keyframes pulse-ring { 0% { box-shadow: 0 0 0 0 rgba(52,211,153,0.5); } 70% { box-shadow: 0 0 0 15px rgba(52,211,153,0); } 100% { box-shadow: 0 0 0 0 rgba(52,211,153,0); } }
      .elite-card { background: #0a0a0a; border: 1px solid rgba(255,255,255,0.04); transition: all 0.5s cubic-bezier(0.23, 1, 0.32, 1); position: relative; overflow: hidden; }
      .elite-card:hover { border-color: rgba(52,211,153,0.3); background: #0d0d0d; box-shadow: 0 20px 35px -12px rgba(0,0,0,0.5); }
      .tech-path { stroke: rgba(255,255,255,0.08); stroke-width: 0.8; fill: none; transition: all 0.6s ease; }
      .elite-card:hover .tech-path { stroke: rgba(52,211,153,0.4); stroke-width: 1.2; }
      .tech-path-primary { stroke: rgba(52,211,153,0.2); stroke-dasharray: 600; stroke-dashoffset: 600; }
      .elite-card:hover .tech-path-primary { stroke-dashoffset: 0; stroke: #34d399; }
      .node-pulse { fill: #34d399; filter: blur(2px); animation: pulseGlow 2s ease-in-out infinite; }
      @keyframes pulseGlow { 0%, 100% { opacity: 0.4; } 50% { opacity: 1; } }
      .mask-fade-bottom { mask-image: linear-gradient(to bottom, black 50%, transparent 100%); }
      @keyframes marquee-ltr { 0% { transform: translateX(0); } 100% { transform: translateX(-50%); } }
      @keyframes marquee-rtl { 0% { transform: translateX(-50%); } 100% { transform: translateX(0); } }
      .marquee-track { display: flex; width: max-content; gap: 1.5rem; padding: 1rem 0; }
      .marquee-ltr { animation: marquee-ltr 60s linear infinite; }
      .marquee-rtl { animation: marquee-rtl 60s linear infinite; }
      .marquee-container:hover .marquee-track { animation-play-state: paused; }
      .review-card { width: 350px; background: #0a0a0a; border: 1px solid rgba(255,255,255,0.05); padding: 1.5rem; border-radius: 1rem; transition: border-color 0.3s ease; }
      .review-card:hover { border-color: rgba(52,211,153,0.2); transform: translateY(-4px); }
      .mask-fade-edges { mask-image: linear-gradient(to right, transparent, black 15%, black 85%, transparent); }
      .bracket-card { background: #0a0a0a; border: 1px solid rgba(255,255,255,0.04); transition: all 0.5s cubic-bezier(0.23, 1, 0.32, 1); position: relative; overflow: hidden; }
      .bracket-card:hover { border-color: rgba(52,211,153,0.3); background: rgba(20,20,25,0.6); }
      .btn-liquid { position: relative; overflow: hidden; display: inline-flex; align-items: center; justify-content: center; transition: all 0.4s cubic-bezier(0.23, 1, 0.32, 1); z-index: 1; border-radius: 9999px; }
      .btn-liquid .liquid-bg { position: absolute; top: 100%; left: 0; width: 100%; height: 100%; background: white; transition: transform 0.4s cubic-bezier(0.23, 1, 0.32, 1); z-index: -1; }
      .btn-liquid:hover .liquid-bg { transform: translateY(-100%); }
      .btn-liquid:hover { color: #030303 !important; }
      .text-glow-emerald { text-shadow: 0 0 30px rgba(52,211,153,0.4); }
      .reveal-y { opacity: 0; transform: translateY(30px); }
      .glass-card { background: rgba(24,24,27,0.4); backdrop-filter: blur(24px); border: 1px solid rgba(255,255,255,0.05); }
      .pricing-card { background: #0a0a0a; border: 1px solid rgba(255,255,255,0.06); border-radius: 1.5rem; padding: 2rem; transition: all 0.4s ease; }
      .pricing-card:hover { border-color: rgba(52,211,153,0.3); transform: translateY(-4px); }
      .pricing-card.featured { border-color: rgba(52,211,153,0.4); background: linear-gradient(145deg, #0d1a14, #0a0a0a); }
      .roadmap-line { width: 2px; background: linear-gradient(180deg, #34d399, rgba(52,211,153,0.1)); }
      .roadmap-dot { width: 12px; height: 12px; border-radius: 50%; border: 2px solid #34d399; background: #030303; }
      .roadmap-dot.active { background: #34d399; box-shadow: 0 0 12px rgba(52,211,153,0.6); }
    </style>
  </head>
  <body>
    {@inner_content}
  </body>
</html>
