<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <title>EQUINOX | Institutional Digital Asset Infrastructure</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500&family=Playfair+Display:ital,wght@0,500;0,600;0,700;1,500;1,600;1,700;1,800;1,900&display=swap"
      rel="stylesheet"
    />
    <%!-- Asset Bundles --%>
    <link phx-track-static rel="stylesheet" href={~p"/assets/app.css"} />
    <script defer phx-track-static type="text/javascript" src={~p"/assets/app.js"}>
    </script>

    <%!-- Vendor CDNs (To be bundled in future iterations for 100% offline sovereignty) --%>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js">
    </script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js">
    </script>
    <script type="importmap">
      {
        "imports": {
          "three": "https://unpkg.com/three@0.128.0/build/three.module.js",
          "three/addons/": "https://unpkg.com/three@0.128.0/examples/jsm/"
        }
      }
    </script>
    <script src="https://unpkg.com/lucide@latest">
    </script>
  </head>
  <body class="bg-obsidian text-white antialiased">
    <%!-- Global UI Elements --%>
    <div class="fixed inset-0 bg-grid pointer-events-none z-0"></div>
    <div class="noise-overlay"></div>
    <div id="cursor-dot"></div>
    <div id="cursor-ring"></div>

    <%!-- Main Navigation --%>
    <nav
      id="main-nav"
      class="fixed top-0 left-1/2 -translate-x-1/2 w-[calc(100%-2rem)] max-w-7xl mt-4 z-[100] rounded-full glass-nav px-6 py-4 flex justify-between items-center"
    >
      <div class="flex items-center gap-3">
        <div class="w-8 h-8 bg-emerald-400 rotate-45 flex items-center justify-center">
          <div class="w-4 h-4 border-2 border-obsidian rotate-45"></div>
        </div>
        <span class="font-mono text-[11px] tracking-[0.3em] uppercase font-bold bg-gradient-to-r from-white to-emerald-400 bg-clip-text text-transparent">
          Equinox
        </span>
      </div>
      <div class="hidden md:flex items-center gap-8">
        <a
          href="#features"
          class="nav-link font-mono text-[9px] uppercase tracking-widest text-zinc-400 hover:text-white transition-colors"
        >
          Infrastructure
        </a>
        <a
          href="#technology"
          class="nav-link font-mono text-[9px] uppercase tracking-widest text-zinc-400 hover:text-white transition-colors"
        >
          MPC Vaults
        </a>
        <a
          href="#roadmap"
          class="nav-link font-mono text-[9px] uppercase tracking-widest text-zinc-400 hover:text-white transition-colors"
        >
          Roadmap
        </a>
        <a
          href="#security"
          class="nav-link font-mono text-[9px] uppercase tracking-widest text-zinc-400 hover:text-white transition-colors"
        >
          Security
        </a>
      </div>
      <div class="flex items-center gap-4">
        <a
          href={~p"/login"}
          class="font-mono text-[9px] uppercase tracking-widest text-zinc-400 hover:text-white transition-colors"
        >
          Login
        </a>
        <a
          href={~p"/register"}
          class="bg-emerald-400 text-obsidian px-5 py-2 rounded-full font-mono text-[9px] uppercase tracking-widest font-bold hover:bg-emerald-300 transition-all shadow-[0_0_15px_rgba(52,211,153,0.3)]"
        >
          Request Access
        </a>
      </div>
    </nav>

    <%!-- Page Content --%>
    <main>
      {@inner_content}
    </main>

    <%!-- Institutional Footer --%>
    <footer class="border-t border-white/5 py-24 px-4 bg-zinc-950/50 relative overflow-hidden">
      <div class="max-w-7xl mx-auto relative z-10">
        <div class="grid grid-cols-1 md:grid-cols-4 gap-16 mb-24">
          <div class="md:col-span-2">
            <h2 class="text-4xl font-serif italic mb-6">
              The Future is <span class="text-emerald-400">Verifiable.</span>
            </h2>
            <p class="text-zinc-400 text-lg font-light leading-relaxed max-w-sm mb-8">
              Secure your institution's digital future with Equinox. Onboard in as little as 48 hours.
            </p>
            <div class="flex items-center gap-3">
              <div class="w-6 h-6 bg-emerald-400 rotate-45 flex items-center justify-center">
                <div class="w-3 h-3 border border-obsidian rotate-45"></div>
              </div>
              <span class="font-mono text-[10px] tracking-[0.3em] uppercase font-bold text-white">
                Equinox
              </span>
            </div>
          </div>

          <div>
            <div class="font-mono text-[9px] text-zinc-600 uppercase tracking-[0.3em] mb-8">
              Product
            </div>
            <ul class="space-y-4">
              <li>
                <a href="#" class="text-zinc-400 hover:text-emerald-400 text-sm transition-colors">
                  Infrastructure
                </a>
              </li>
              <li>
                <a href="#" class="text-zinc-400 hover:text-emerald-400 text-sm transition-colors">
                  MPC Vaults
                </a>
              </li>
              <li>
                <a href="#" class="text-zinc-400 hover:text-emerald-400 text-sm transition-colors">
                  Settlement Engine
                </a>
              </li>
            </ul>
          </div>

          <div>
            <div class="font-mono text-[9px] text-zinc-600 uppercase tracking-[0.3em] mb-8">
              Resources
            </div>
            <ul class="space-y-4">
              <li>
                <a href="#" class="text-zinc-400 hover:text-emerald-400 text-sm transition-colors">
                  Documentation
                </a>
              </li>
              <li>
                <a href="#" class="text-zinc-400 hover:text-emerald-400 text-sm transition-colors">
                  Whitepapers
                </a>
              </li>
              <li>
                <a href="#" class="text-zinc-400 hover:text-emerald-400 text-sm transition-colors">
                  Audit Reports
                </a>
              </li>
            </ul>
          </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-4 gap-16 border-t border-white/5 pt-16">
          <div class="md:col-span-2">
            <div class="font-mono text-[9px] text-zinc-600 uppercase tracking-[0.3em] mb-6">
              Stay Informed
            </div>
            <p class="text-zinc-500 text-xs mb-6 font-light">
              Receive institutional market insights and system updates.
            </p>
            <form class="flex gap-2 max-w-sm">
              <input
                type="email"
                placeholder="institutional@email.com"
                class="bg-white/5 border border-white/10 rounded-lg px-4 py-2 text-sm focus:outline-none focus:border-emerald-400 transition-colors w-full"
              />
              <button class="bg-emerald-400 text-obsidian px-4 py-2 rounded-lg font-mono text-[9px] uppercase tracking-widest font-bold">
                Join
              </button>
            </form>
          </div>

          <div class="md:col-span-2 flex flex-col justify-end items-start md:items-end">
            <div class="flex gap-6 mb-8 filter grayscale opacity-40 hover:opacity-100 transition-opacity">
              <span class="font-mono text-[9px] tracking-widest text-white border border-white/20 px-2 py-1 rounded">
                SOC2
              </span>
              <span class="font-mono text-[9px] tracking-widest text-white border border-white/20 px-2 py-1 rounded">
                ISO 27001
              </span>
              <span class="font-mono text-[9px] tracking-widest text-white border border-white/20 px-2 py-1 rounded">
                FIPS 140-3
              </span>
            </div>
            <div class="flex flex-col md:flex-row gap-4 md:gap-8 items-start md:items-center">
              <span class="font-mono text-[9px] text-zinc-700 tracking-widest uppercase">
                © 2025 Equinox Infrastructure Ltd
              </span>
              <a
                href="#"
                class="font-mono text-[9px] text-zinc-500 hover:text-white transition-colors uppercase tracking-widest"
              >
                Privacy Policy
              </a>
              <a
                href="#"
                class="font-mono text-[9px] text-zinc-500 hover:text-white transition-colors uppercase tracking-widest"
              >
                Terms of Service
              </a>
            </div>
          </div>
        </div>
      </div>

      <%!-- Decorative elements --%>
      <div class="absolute bottom-0 right-0 w-[500px] h-[500px] bg-emerald-500/5 blur-[120px] rounded-full -mb-64 -mr-64 pointer-events-none">
      </div>
    </footer>
  </body>
</html>
