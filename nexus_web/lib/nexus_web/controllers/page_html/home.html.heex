<main class="relative z-10">
  <!-- Hero Section -->
  <section class="min-h-screen flex flex-col justify-center items-center px-4 pt-28 pb-20 relative">
    <div class="absolute top-1/4 left-1/2 -translate-x-1/2 w-[600px] h-[600px] bg-emerald-500/10 blur-[120px] rounded-full -z-10">
    </div>

    <h1 class="hero-title font-serif italic text-center max-w-6xl mb-12">
      <span class="block opacity-0 translate-y-10" id="hero-line-1">One Platform.</span>
      <span
        class="block text-emerald-400 opacity-0 translate-y-10 text-glow-emerald"
        id="hero-line-2"
      >
        Every Subsidiary. Every Currency.
      </span>
    </h1>

    <p
      id="hero-desc"
      class="text-zinc-400 text-lg md:text-xl max-w-2xl text-center mb-12 opacity-0 font-light translate-y-10"
    >
      The treasury operating system for multinationals. Real-time FX exposure, automated intercompany netting, and compliance by design — across every entity, from a single pane of glass.
    </p>

    <div class="flex flex-col md:flex-row gap-6 opacity-0" id="hero-ctas">
      <a
        href={~p"/request-access"}
        class="btn-liquid bg-emerald-400 text-obsidian px-10 py-5 font-mono text-xs tracking-widest uppercase font-bold shadow-[0_0_30px_rgba(52,211,153,0.3)]"
      >
        <span class="relative z-10">Request Private Access</span>
        <div class="liquid-bg"></div>
      </a>
      <a
        href="#features"
        class="btn-liquid px-10 py-5 border border-white/20 hover:border-emerald-400 transition-colors font-mono text-xs tracking-widest uppercase text-white"
      >
        <span class="relative z-10">See Platform Demo</span>
        <div class="liquid-bg bg-white/5"></div>
      </a>
    </div>

    <div class="grid grid-cols-2 lg:grid-cols-4 gap-8 md:gap-12 mt-20 md:mt-32 w-full max-w-6xl border-t border-white/5 pt-12">
      <div class="reveal-y">
        <div class="text-[10px] font-mono uppercase tracking-[0.3em] text-zinc-500 mb-3 flex items-center gap-2">
          <span class="w-1 h-1 bg-emerald-400 rounded-full shadow-[0_0_8px_#34d399]"></span>
          Interco Volume Settled
        </div>
        <div class="text-4xl md:text-5xl font-light tracking-tighter mb-1">
          <span class="counter" data-target="2.8">0</span><span class="text-emerald-400 ml-1 italic font-serif">B</span>
        </div>
        <div class="text-[10px] font-mono text-zinc-600 uppercase tracking-widest">
          Billion USD
        </div>
      </div>
      <div class="reveal-y">
        <div class="text-[10px] font-mono uppercase tracking-[0.3em] text-zinc-500 mb-3 flex items-center gap-2">
          <span class="w-1 h-1 bg-emerald-400 rounded-full shadow-[0_0_8px_#34d399]"></span>
          Settlement Speed
        </div>
        <div class="text-4xl md:text-5xl font-light tracking-tighter mb-1">
          <span class="counter" data-target="0.14">0</span><span class="text-emerald-400 ml-1 italic font-serif">S</span>
        </div>
        <div class="text-[10px] font-mono text-zinc-600 uppercase tracking-widest">Seconds</div>
      </div>
      <div class="reveal-y">
        <div class="text-[10px] font-mono uppercase tracking-[0.3em] text-zinc-500 mb-3 flex items-center gap-2">
          <span class="w-1 h-1 bg-emerald-400 rounded-full shadow-[0_0_8px_#34d399]"></span>
          Managed Entities
        </div>
        <div class="text-4xl md:text-5xl font-light tracking-tighter mb-1">
          <span class="counter" data-target="142">0</span>
        </div>
        <div class="text-[10px] font-mono text-zinc-600 uppercase tracking-widest">
          Subsidiaries
        </div>
      </div>
      <div class="reveal-y">
        <div class="text-[10px] font-mono uppercase tracking-[0.3em] text-zinc-500 mb-3 flex items-center gap-2">
          <span class="w-1 h-1 bg-emerald-400 rounded-full shadow-[0_0_8px_#34d399]"></span>
          Compliance Rate
        </div>
        <div class="text-4xl md:text-5xl font-light tracking-tighter mb-1">
          <span class="counter" data-target="100">0</span><span class="text-emerald-400 ml-1 italic font-serif">%</span>
        </div>
        <div class="text-[10px] font-mono text-zinc-600 uppercase tracking-widest">
          Percent Certified
        </div>
      </div>
    </div>
  </section>
  
<!-- Partner Marquee -->
  <section class="py-12 border-y border-white/5 bg-zinc-950/20 overflow-hidden">
    <div class="flex animate-marquee whitespace-nowrap gap-12 items-center">
      <div class="flex items-center gap-24 px-12 opacity-40 hover:opacity-100 transition-opacity">
        <span class="text-2xl font-bold tracking-tighter">SHELL</span>
        <span class="text-2xl font-bold tracking-tighter">SIEMENS</span>
        <span class="text-2xl font-bold tracking-tighter">MTN GROUP</span>
        <span class="text-2xl font-bold tracking-tighter">UNILEVER</span>
        <span class="text-2xl font-bold tracking-tighter">ABB</span>
        <span class="text-2xl font-bold tracking-tighter">NESTLÉ</span>
      </div>
      <div class="flex items-center gap-24 px-12 opacity-40 hover:opacity-100 transition-opacity">
        <span class="text-2xl font-bold tracking-tighter">SHELL</span>
        <span class="text-2xl font-bold tracking-tighter">SIEMENS</span>
        <span class="text-2xl font-bold tracking-tighter">MTN GROUP</span>
        <span class="text-2xl font-bold tracking-tighter">UNILEVER</span>
        <span class="text-2xl font-bold tracking-tighter">ABB</span>
        <span class="text-2xl font-bold tracking-tighter">NESTLÉ</span>
      </div>
    </div>
  </section>
  
<!-- REALISTIC 3D GLOBE with Transaction Notifications -->
  <section id="globe-section" class="py-24 relative overflow-hidden">
    <div class="max-w-7xl mx-auto px-4">
      <div class="text-center mb-12">
        <h2 class="text-5xl font-serif italic mb-4">
          The Global <span class="text-emerald-400">Treasury Mesh</span>
        </h2>
        <p class="text-zinc-400 text-lg max-w-2xl mx-auto font-light">
          142 multinational entities across 6 continents |
          <span class="text-emerald-400 font-mono" id="latency-value">45ms</span>
          avg latency | <span id="active-flows" class="text-emerald-400">247</span>
          active settlement flows
        </p>
      </div>
      <div
        class="globe-wrapper relative rounded-3xl overflow-hidden shadow-2xl"
        style="height: 650px;"
      >
        <div id="globe-container" class="w-full h-full"></div>
        <div class="globe-glow-overlay"></div>
        <div id="notification-container" class="absolute inset-0 pointer-events-none z-30"></div>

        <div class="absolute bottom-6 left-6 z-20 flex gap-3">
          <div class="bracket-card px-4 py-2 rounded-full text-[10px] font-mono backdrop-blur-md border border-emerald-400/20">
            <span class="text-emerald-400">●</span>
            ACTIVE ENTITIES: <span id="node-counter">142</span>
          </div>
          <div class="bracket-card px-4 py-2 rounded-full text-[10px] font-mono backdrop-blur-md border border-emerald-400/20">
            <span class="text-emerald-400">⚡</span>
            SETTLEMENTS/S: <span id="tx-counter">1,247</span>
          </div>
        </div>
        <div class="absolute top-6 right-6 z-20 bracket-card px-4 py-2 rounded-full text-[10px] font-mono backdrop-blur-md border border-emerald-400/20">
          <span class="text-emerald-400">🌍</span>
          NETTING CYCLES: <span id="flow-counter">12</span>
          active routes
        </div>
      </div>
    </div>
  </section>
  
<!-- Bento Grid Feature Section -->
  <section id="features" class="py-32 px-4 max-w-7xl mx-auto">
    <div class="flex flex-col md:flex-row justify-between items-end mb-16 gap-8">
      <div class="max-w-2xl">
        <h2 class="text-5xl font-serif italic mb-6">
          Built for the <span class="text-emerald-400">Modern Treasurer.</span>
        </h2>
        <p class="text-zinc-400 text-lg font-light">
          Every component of Equinox is engineered for the realities of global enterprise finance — not retrofitted for compliance, but built with it at the core.
        </p>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-12 gap-5 auto-rows-[320px]">
      <!-- 1. Postgres Database Card -->
      <div class="md:col-span-8 elite-card p-10 rounded-3xl flex flex-col md:flex-row justify-between items-center group cursor-pointer">
        <div class="max-w-md z-10">
          <div class="flex items-center gap-3 mb-6">
            <i data-lucide="database" class="w-4 h-4 text-emerald-400"></i>
            <span class="font-mono text-[9px] text-zinc-600 tracking-[0.4em] uppercase">
              Immutable Protocol
            </span>
          </div>
          <h3 class="text-4xl font-serif italic mb-6">Every Transaction. Forever Traceable.</h3>
          <p class="text-zinc-500 text-sm font-light leading-relaxed mb-6">
            Equinox records every financial event as an immutable fact — from policy changes to settlement confirmations. Complete audit-readiness is built in, not bolted on.
          </p>
          <div class="flex gap-4">
            <span class="px-3 py-1 border border-white/5 rounded font-mono text-[8px] text-zinc-500 uppercase">
              SOC 2 Ready
            </span>
            <span class="px-3 py-1 border border-white/5 rounded font-mono text-[8px] text-zinc-500 uppercase">
              Tamper-Proof
            </span>
          </div>
        </div>
        <div class="relative w-72 h-72 flex items-center justify-center">
          <svg
            viewBox="0 0 240 240"
            class="w-full h-full transform transition-all duration-700 group-hover:scale-110"
          >
            <g class="parallax-layer" data-speed="0.05">
              <circle cx="120" cy="120" r="100" class="tech-path" stroke-dasharray="4 8" />
              <circle cx="120" cy="120" r="85" class="tech-path" stroke-opacity="0.3" />
              <line x1="120" y1="20" x2="120" y2="220" class="tech-path" stroke-opacity="0.1" />
              <line x1="20" y1="120" x2="220" y2="120" class="tech-path" stroke-opacity="0.1" />
            </g>
            <g class="parallax-layer" data-speed="0.1">
              <path
                class="tech-path tech-path-primary"
                d="M160 120 C160 60, 80 60, 80 120 C80 180, 160 180, 160 120"
              />
              <path
                class="tech-path tech-path-primary"
                d="M120 80 C140 80, 175 100, 175 135 C175 170, 140 185, 120 185"
              />
              <circle cx="150" cy="105" r="3" class="node-pulse" />
              <circle cx="90" cy="135" r="3" class="node-pulse" style="animation-delay: 0.5s;" />
              <circle
                cx="120"
                cy="120"
                r="5"
                class="fill-emerald-400/20 stroke-emerald-400 stroke-1"
              />
            </g>
            <g class="parallax-layer opacity-20" data-speed="0.15">
              <line x1="150" y1="105" x2="120" y2="120" class="tech-path" stroke-dasharray="2 4" />
              <line x1="90" y1="135" x2="120" y2="120" class="tech-path" stroke-dasharray="2 4" />
            </g>
          </svg>
        </div>
      </div>
      
<!-- 2. Auth Vault Card -->
      <div class="md:col-span-4 elite-card p-10 rounded-3xl group flex flex-col justify-between">
        <div>
          <div class="flex items-center gap-3 mb-4">
            <i data-lucide="shield-check" class="w-4 h-4 text-emerald-400"></i>
            <span class="font-mono text-[9px] text-zinc-600 tracking-[0.4em] uppercase">
              Identity
            </span>
          </div>
          <h3 class="text-2xl font-serif italic mb-4">Auth_Vault</h3>
          <p class="text-zinc-500 text-xs font-light">
            Passwordless access via hardware-backed WebAuthn. Touch ID and Windows Hello for treasury operators — with step-up authorization for high-value transfers. Zero phishing surface.
          </p>
        </div>
        <div class="relative flex flex-col gap-2 mt-8 mask-fade-bottom overflow-hidden">
          <div class="h-10 border border-white/5 rounded-lg bg-zinc-950/80 flex items-center px-4 font-mono text-[8px] text-zinc-600 transition-all group-hover:border-emerald-500/30 group-hover:text-emerald-400">
            admin_01@vanguard.ch
          </div>
          <div class="h-10 border border-white/5 rounded-lg bg-zinc-950/80 flex items-center px-4 font-mono text-[8px] text-zinc-600">
            operator_delta@blackrock.io
          </div>
          <div class="h-10 border border-white/5 rounded-lg bg-zinc-950/80 flex items-center px-4 font-mono text-[8px] text-zinc-800">
            node_root@equinox.io
          </div>
        </div>
      </div>
      
<!-- 3. Edge Functions Card -->
      <div class="md:col-span-4 elite-card p-10 rounded-3xl group flex flex-col items-center text-center">
        <div class="w-full flex items-center gap-3 mb-4">
          <i data-lucide="git-merge" class="w-4 h-4 text-emerald-400"></i>
          <span class="font-mono text-[8px] text-zinc-700 uppercase tracking-widest">
            Settlement
          </span>
        </div>
        <h3 class="text-2xl font-serif italic mb-3">Interco Netting</h3>
        <p class="text-zinc-500 text-xs font-light mb-8 max-w-[200px]">
          Automated multi-currency netting cycles across all subsidiaries. What took 12 days settles in seconds.
        </p>
        <div class="relative w-full flex-1 flex items-center justify-center">
          <svg viewBox="0 0 200 200" class="w-48 h-48" id="globe-viz">
            <circle cx="100" cy="100" r="85" class="tech-path" stroke-opacity="0.1" />
            <circle
              cx="100"
              cy="100"
              r="85"
              class="tech-path tech-path-primary"
              stroke-dasharray="2 12"
            />
            <ellipse
              cx="100"
              cy="100"
              rx="85"
              ry="35"
              class="tech-path"
              transform="rotate(45 100 100)"
            />
            <ellipse
              cx="100"
              cy="100"
              rx="85"
              ry="35"
              class="tech-path"
              transform="rotate(-45 100 100)"
            />
            <circle cx="100" cy="100" r="4" class="node-pulse" />
            <circle cx="30" cy="100" r="2" class="node-pulse opacity-20" />
            <circle cx="170" cy="100" r="2" class="node-pulse opacity-20" />
          </svg>
          <div class="absolute bottom-2 font-mono text-[9px] text-emerald-400 opacity-0 group-hover:opacity-100 transition-opacity uppercase tracking-widest">
            Global Sync Active
          </div>
        </div>
      </div>
      
<!-- 4. Realtime Sync Card -->
      <div class="md:col-span-4 elite-card p-10 rounded-3xl group flex flex-col">
        <div class="flex items-center gap-3 mb-4">
          <i data-lucide="zap" class="w-4 h-4 text-emerald-400"></i>
          <span class="font-mono text-[9px] text-zinc-600 tracking-[0.4em] uppercase">
            Realtime
          </span>
        </div>
        <h3 class="text-2xl font-serif italic mb-4">Live FX Exposure</h3>
        <p class="text-zinc-500 text-xs font-light mb-8">
          Real-time FX exposure across every entity. Policy thresholds, liquidity heatmaps, and breach alerts — the moment the market moves, you know.
        </p>
        <div class="flex-1 relative bg-zinc-950/50 rounded-2xl border border-white/5 overflow-hidden h-28">
          <div class="absolute inset-0 bg-[radial-gradient(rgba(52,211,153,0.08)_1px,transparent_1px)] [background-size:24px_24px]">
          </div>
          <div
            id="cursor-ghost-1"
            class="absolute pointer-events-none text-emerald-400 opacity-0 group-hover:opacity-100 transition-opacity"
          >
            <i data-lucide="mouse-pointer-2" class="w-4 h-4 fill-emerald-400/20"></i>
            <div class="ml-4 mt-2 px-2 py-1 bg-emerald-400 text-obsidian font-mono text-[7px] font-bold">
              NODE_ALPHA
            </div>
          </div>
          <div
            id="cursor-ghost-2"
            class="absolute pointer-events-none text-zinc-700 opacity-40 group-hover:opacity-80 transition-opacity"
          >
            <i data-lucide="mouse-pointer-2" class="w-4 h-4"></i>
          </div>
          <div
            id="cursor-ghost-3"
            class="absolute pointer-events-none text-emerald-600/30 opacity-0 group-hover:opacity-100 transition-opacity"
          >
            <i data-lucide="mouse-pointer-2" class="w-4 h-4"></i>
            <div class="ml-4 mt-2 px-2 py-1 border border-emerald-400/20 text-emerald-400 font-mono text-[6px]">
              SYSTEM_ROOT
            </div>
          </div>
        </div>
      </div>
      
<!-- 5. Vector Search Card -->
      <div class="md:col-span-4 elite-card p-10 rounded-3xl group flex flex-col h-full">
        <div class="flex items-center gap-3 mb-4">
          <i data-lucide="shield-check" class="w-4 h-4 text-emerald-400"></i>
          <span class="font-mono text-[9px] text-zinc-600 tracking-[0.4em] uppercase">
            Compliance
          </span>
        </div>
        <h3 class="text-2xl font-serif italic mb-4">SoD Enforcement</h3>
        <p class="text-zinc-500 text-xs font-light mb-8">
          Live Segregation of Duties monitoring. Toxic role combinations detected and remediated automatically — before your auditors find them.
        </p>
        <div class="flex-1 relative flex items-center justify-center overflow-hidden">
          <svg viewBox="0 0 200 200" class="w-48 h-48">
            <g class="parallax-layer" data-speed="0.2">
              <rect x="60" y="60" width="80" height="80" class="tech-path" />
              <rect
                x="75"
                y="45"
                width="80"
                height="80"
                class="tech-path tech-path-primary"
                stroke-opacity="0.5"
              />
              <line x1="60" y1="60" x2="75" y2="45" class="tech-path" />
              <line x1="140" y1="60" x2="155" y2="45" class="tech-path" />
              <line x1="60" y1="140" x2="75" y2="125" class="tech-path" />
              <line x1="140" y1="140" x2="155" y2="125" class="tech-path" />
            </g>
            <!-- High density dots -->
            <g id="vector-dots-matrix"></g>
          </svg>
        </div>
      </div>
    </div>
  </section>
  
<!-- Expandable Modules / Accordions -->
  <section id="accordions" class="py-32 px-4 max-w-4xl mx-auto">
    <h2 class="text-5xl font-serif italic mb-16 text-center">
      Technical <span class="text-emerald-400">Deep Dive</span>
    </h2>
    <div class="space-y-4">
      <div class="accordion-item border border-white/10 rounded-2xl overflow-hidden glass-card">
        <button class="accordion-trigger w-full flex justify-between items-center p-6 text-left font-bold text-lg hover:bg-white/5 transition-colors">
          <span>🔐 Biometric Authentication & Step-Up Authorization</span>
          <span class="accordion-icon transition-transform duration-300">+</span>
        </button>
        <div class="accordion-content">
          <div class="p-6 pt-0 border-t border-white/5 mt-2">
            <pre
              phx-no-curly-interpolation
              class="font-mono text-xs bg-black/50 p-4 rounded-lg overflow-x-auto"
            ><span class="text-emerald-400">$</span> equinox auth enroll --method webauthn --user cfo@meridian.com\n<span class="text-zinc-500">✓ Hardware credential registered: Touch ID (FIDO2/WebAuthn)\n✓ Step-up policy: transfers &gt; $500K require re-authentication\n✓ Zero passwords stored — phishing surface: none</span></pre>
          </div>
        </div>
      </div>
      <div class="accordion-item border border-white/10 rounded-2xl overflow-hidden glass-card">
        <button class="accordion-trigger w-full flex justify-between items-center p-6 text-left font-bold text-lg hover:bg-white/5 transition-colors">
          <span>⚡ Intercompany Netting Engine Architecture</span>
          <span class="accordion-icon transition-transform duration-300">+</span>
        </button>
        <div class="accordion-content">
          <div class="p-6 pt-0 border-t border-white/5 mt-2">
            <div class="grid md:grid-cols-2 gap-4">
              <div class="bg-white/5 p-4 rounded-lg">
                <div class="text-emerald-400 font-mono text-xs">LATENCY</div>
                <div class="text-2xl font-bold">0.14s</div>
              </div>
              <div class="bg-white/5 p-4 rounded-lg">
                <div class="text-emerald-400 font-mono text-xs">THROUGHPUT</div>
                <div class="text-2xl font-bold">1,247 TX/S</div>
              </div>
            </div>
          </div>
        </div>
      </div>
      <div class="accordion-item border border-white/10 rounded-2xl overflow-hidden glass-card">
        <button class="accordion-trigger w-full flex justify-between items-center p-6 text-left font-bold text-lg hover:bg-white/5 transition-colors">
          <span>🌐 Multi-Entity Settlement Mesh</span>
          <span class="accordion-icon transition-transform duration-300">+</span>
        </button>
        <div class="accordion-content">
          <div class="p-6 pt-0 border-t border-white/5 mt-2">
            <div class="flex flex-wrap gap-2 text-zinc-400 text-sm font-light">
              <span class="px-3 py-1 bg-emerald-400/5 border border-emerald-400/10 rounded-full">
                North America: 48 entities
              </span>
              <span class="px-3 py-1 bg-emerald-400/5 border border-emerald-400/10 rounded-full">
                Europe: 52 entities
              </span>
              <span class="px-3 py-1 bg-emerald-400/5 border border-emerald-400/10 rounded-full">
                APAC: 31 entities
              </span>
              <span class="px-3 py-1 bg-emerald-400/5 border border-emerald-400/10 rounded-full">
                Africa: 11 entities
              </span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
  
<!-- Testimonial Marquee Section -->
  <section id="carousel" class="py-32 relative z-10 overflow-hidden">
    <div class="max-w-7xl mx-auto text-center mb-16 px-6">
      <h2 class="text-5xl md:text-7xl font-serif italic mb-6">
        Trusted by <span class="text-emerald-400">Global Institutions</span>
      </h2>
      <p class="text-zinc-500 font-light max-w-2xl mx-auto text-lg mb-8">
        What Group Treasurers, CFOs, and Finance Controllers say about running their treasury on Equinox.
      </p>
      <div class="flex justify-center gap-4">
        <button class="bg-zinc-900 border border-white/10 px-6 py-3 rounded-md font-mono text-[10px] uppercase tracking-widest flex items-center gap-3 hover:bg-zinc-800 transition-colors">
          <i data-lucide="users" class="w-4 h-4"></i> Join Institutional Network
        </button>
      </div>
    </div>

    <div class="marquee-container mask-fade-edges relative max-w-7xl mx-auto px-4 overflow-hidden">
      <!-- Row 1: Left to Right -->
      <div class="marquee-track marquee-ltr">
        <div class="review-card">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-8 h-8 rounded-full bg-emerald-400/20 flex items-center justify-center text-emerald-400 text-xs font-bold">
              CF
            </div>
            <div>
              <div class="text-[10px] font-bold">@cfernandez</div>
              <div class="text-[8px] text-zinc-600 uppercase font-mono tracking-tighter">
                Group Treasurer, Meridian Holdings
              </div>
            </div>
