  <section class="py-32 px-4 max-w-7xl mx-auto">
    <div class="grid md:grid-cols-2 gap-20 items-center">
      <div>
        <div class="bracket-card rounded-2xl overflow-hidden shadow-2xl">
          <div class="terminal-header px-6 py-3 flex items-center gap-2">
            <div class="dot dot-red"></div>
            <div class="dot dot-yellow"></div>
            <div class="dot dot-green"></div>
            <span class="font-mono text-[10px] text-zinc-500 ml-4">equinox-sdk.js</span>
          </div>
          <div
            phx-no-curly-interpolation
            class="p-8 font-mono text-sm leading-relaxed bg-obsidian"
          >
            <div class="text-zinc-500">// Initialize Equinox treasury gateway</div>
            <div>
              <span class="text-emerald-400">const</span>
              client = <span class="text-emerald-400">new</span>
              Equinox({ apiKey: <span class="text-zinc-400">'eq_live_v4_...'</span>
              });
            </div>
            <div class="mt-4">
              <span class="text-emerald-400">await</span> client.netting.runCycle({
            </div>
            <div class="ml-4">
              entities: [<span class="text-zinc-400">'sub_uk'</span>, <span class="text-zinc-400">'sub_ae'</span>, <span class="text-zinc-400">'sub_ng'</span>],
            </div>
            <div class="ml-4">currency: <span class="text-zinc-400">'USD'</span></div>
            <div>});</div>
            <div class="mt-4 text-emerald-400">
              ✓ Netting cycle settled: 3 entities · $4.2M · 0.14s
            </div>
            <div class="typing-cursor mt-2"></div>
          </div>
        </div>
      </div>
      <div>
        <h2 class="text-5xl font-serif italic mb-8">
          Built by Finance Engineers. <br />For
          <span class="text-emerald-400">Finance Engineers.</span>
        </h2>
        <p class="text-zinc-400 text-lg mb-8">
          Deploy treasury workflows at institutional scale. Event-sourced architecture you can trust. SDKs in Elixir, Python, and TypeScript.
        </p>
        <ul class="space-y-4">
          <li class="flex gap-4">
            <i data-lucide="layers" class="text-emerald-400 w-5 h-5"></i><span class="text-zinc-300 font-light">Every transaction is an immutable, replayable event — by design.</span>
          </li>
          <li class="flex gap-4">
            <i data-lucide="git-branch" class="text-emerald-400 w-5 h-5"></i><span class="text-zinc-300 font-light">CQRS: commands and queries fully separated for audit-safe operations.</span>
          </li>
          <li class="flex gap-4">
            <i data-lucide="fingerprint" class="text-emerald-400 w-5 h-5"></i><span class="text-zinc-300 font-light">WebAuthn SDK: hardware-backed identity in one line of code.</span>
          </li>
        </ul>
      </div>
    </div>
  </section>
  
