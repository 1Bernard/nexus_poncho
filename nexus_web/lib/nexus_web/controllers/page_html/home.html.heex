<div id="cursor-dot"></div>
<div id="cursor-ring"></div>
<div class="noise-overlay"></div>
<div class="fixed inset-0 bg-grid pointer-events-none z-0"></div>

<!-- Navigation -->
<nav
  id="main-nav"
  class="fixed top-0 left-1/2 -translate-x-1/2 mt-6 w-[90%] max-w-7xl z-50 rounded-full border border-white/10 glass-nav px-8 py-3.5 flex items-center justify-between"
>
  <div class="flex items-center gap-3">
    <div class="w-8 h-8 bg-emerald-400 rotate-45 flex items-center justify-center transition-all duration-300 hover:rotate-90">
      <div class="w-4 h-4 border-2 border-obsidian rotate-45"></div>
    </div>
    <span class="font-mono text-[11px] tracking-[0.3em] uppercase font-bold bg-gradient-to-r from-white to-emerald-400 bg-clip-text text-transparent">
      Equinox
    </span>
  </div>
  <div class="hidden md:flex items-center gap-10 font-mono text-[10px] tracking-widest uppercase">
    <a href="#features" class="nav-link text-zinc-400 hover:text-emerald-400 transition-colors">
      Platform
    </a>
    <a
      href="#testimonials"
      class="nav-link text-zinc-400 hover:text-emerald-400 transition-colors"
    >
      Testimonials
    </a>
    <a href="#technology" class="nav-link text-zinc-400 hover:text-emerald-400 transition-colors">
      How It Works
    </a>
    <a href="#pricing" class="nav-link text-zinc-400 hover:text-emerald-400 transition-colors">
      Pricing
    </a>
    <a href="#roadmap" class="nav-link text-zinc-400 hover:text-emerald-400 transition-colors">
      Roadmap
    </a>
    <a href="#security" class="nav-link text-zinc-400 hover:text-emerald-400 transition-colors">
      Security
    </a>
  </div>
  <div class="flex items-center gap-4">
    <a
      href={~p"/login"}
      class="btn-liquid px-6 py-2 text-[10px] font-mono tracking-widest uppercase text-zinc-400 hover:text-white transition-colors"
    >
      <span class="relative z-10">Login</span>
      <div class="liquid-bg bg-white/10"></div>
    </a>
    <a
      href={~p"/register"}
      class="btn-liquid bg-emerald-400 text-obsidian px-6 py-2 text-[10px] font-mono tracking-widest uppercase font-bold shadow-[0_0_15px_rgba(52,211,153,0.2)]"
    >
      <span class="relative z-10">Request Access</span>
      <div class="liquid-bg"></div>
    </a>
  </div>
</nav>

<main class="relative z-10">
  
<!-- ── Hero ─────────────────────────────────────────────────────────────── -->
  <section class="min-h-screen flex flex-col justify-center items-center px-4 pt-28 pb-20 relative">
    <div class="absolute top-1/4 left-1/2 -translate-x-1/2 w-[600px] h-[600px] bg-emerald-500/10 blur-[120px] rounded-full -z-10">
    </div>

    <div class="mb-8 flex items-center gap-3 opacity-0" id="hero-badge">
      <span class="w-1.5 h-1.5 bg-emerald-400 rounded-full animate-pulse shadow-[0_0_8px_#34d399]">
      </span>
      <span class="font-mono text-[10px] tracking-[0.4em] uppercase text-zinc-500">
        Enterprise Treasury Intelligence · Now in Private Access
      </span>
    </div>

    <h1 class="hero-title font-serif italic text-center max-w-6xl mb-12">
      <span class="block opacity-0 translate-y-10" id="hero-line-1">Total Treasury</span>
      <span
        class="block text-emerald-400 opacity-0 translate-y-10 text-glow-emerald"
        id="hero-line-2"
      >
        Intelligence.
      </span>
    </h1>

    <p
      id="hero-desc"
      class="text-zinc-400 text-lg md:text-xl max-w-2xl text-center mb-12 opacity-0 font-light translate-y-10"
    >
      Enterprise infrastructure for multinational finance teams. Real-time FX exposure, automated reconciliation, and AI-powered anomaly detection — secured by biometric authentication.
    </p>

    <div class="flex flex-col md:flex-row gap-6 opacity-0" id="hero-ctas">
      <a
        href={~p"/register"}
        class="btn-liquid bg-emerald-400 text-obsidian px-10 py-5 font-mono text-xs tracking-widest uppercase font-bold shadow-[0_0_30px_rgba(52,211,153,0.3)]"
      >
        <span class="relative z-10">Request Access</span>
        <div class="liquid-bg"></div>
      </a>
      <a
        href="#features"
        class="btn-liquid px-10 py-5 border border-white/20 hover:border-emerald-400 transition-colors font-mono text-xs tracking-widest uppercase text-white"
      >
        <span class="relative z-10">Platform Overview</span>
        <div class="liquid-bg bg-white/5"></div>
      </a>
    </div>
    
<!-- Stats -->
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-8 md:gap-12 mt-20 md:mt-32 w-full max-w-6xl border-t border-white/5 pt-12">
      <div class="reveal-y">
        <div class="text-[10px] font-mono uppercase tracking-[0.3em] text-zinc-500 mb-3 flex items-center gap-2">
          <span class="w-1 h-1 bg-emerald-400 rounded-full shadow-[0_0_8px_#34d399]"></span>
          FX Exposure Tracked
        </div>
        <div class="text-4xl md:text-5xl font-light tracking-tighter mb-1">
          $<span class="counter" data-target="1.4">0</span>
          <span class="text-emerald-400 ml-1 italic font-serif">
            B
          </span>
        </div>
        <div class="text-[10px] font-mono text-zinc-600 uppercase tracking-widest">
          Billion USD
        </div>
      </div>
      <div class="reveal-y">
        <div class="text-[10px] font-mono uppercase tracking-[0.3em] text-zinc-500 mb-3 flex items-center gap-2">
          <span class="w-1 h-1 bg-emerald-400 rounded-full shadow-[0_0_8px_#34d399]"></span>
          Forecast Horizon
        </div>
        <div class="text-4xl md:text-5xl font-light tracking-tighter mb-1">
          <span class="counter" data-target="30">0</span><span class="text-emerald-400 ml-1 italic font-serif">D</span>
        </div>
        <div class="text-[10px] font-mono text-zinc-600 uppercase tracking-widest">
          Day Outlook
        </div>
      </div>
      <div class="reveal-y">
        <div class="text-[10px] font-mono uppercase tracking-[0.3em] text-zinc-500 mb-3 flex items-center gap-2">
          <span class="w-1 h-1 bg-emerald-400 rounded-full shadow-[0_0_8px_#34d399]"></span>
          Compliance Controls
        </div>
        <div class="text-4xl md:text-5xl font-light tracking-tighter mb-1">
          <span class="counter" data-target="6">0</span>
        </div>
        <div class="text-[10px] font-mono text-zinc-600 uppercase tracking-widest">
          Real-time Metrics
        </div>
      </div>
      <div class="reveal-y">
        <div class="text-[10px] font-mono uppercase tracking-[0.3em] text-zinc-500 mb-3 flex items-center gap-2">
          <span class="w-1 h-1 bg-emerald-400 rounded-full shadow-[0_0_8px_#34d399]"></span>
          Audit Coverage
        </div>
        <div class="text-4xl md:text-5xl font-light tracking-tighter mb-1">
          <span class="counter" data-target="100">0</span><span class="text-emerald-400 ml-1 italic font-serif">%</span>
        </div>
        <div class="text-[10px] font-mono text-zinc-600 uppercase tracking-widest">
          Immutable Events
        </div>
      </div>
    </div>
  </section>
  
<!-- ── Partner Marquee ───────────────────────────────────────────────────── -->
  <section class="py-12 border-y border-white/5 bg-zinc-950/20 overflow-hidden">
    <div class="flex animate-marquee whitespace-nowrap gap-12 items-center">
      <div class="flex items-center gap-24 px-12 opacity-40 hover:opacity-100 transition-opacity">
        <span class="text-2xl font-bold tracking-tighter">SAP INTEGRATION</span>
        <span class="text-2xl font-bold tracking-tighter">MANUFACTURING</span>
        <span class="text-2xl font-bold tracking-tighter">ENERGY</span>
        <span class="text-2xl font-bold tracking-tighter">LOGISTICS</span>
        <span class="text-2xl font-bold tracking-tighter">RETAIL GROUPS</span>
        <span class="text-2xl font-bold tracking-tighter">FMCG</span>
      </div>
      <div class="flex items-center gap-24 px-12 opacity-40 hover:opacity-100 transition-opacity">
        <span class="text-2xl font-bold tracking-tighter">SAP INTEGRATION</span>
        <span class="text-2xl font-bold tracking-tighter">MANUFACTURING</span>
        <span class="text-2xl font-bold tracking-tighter">ENERGY</span>
        <span class="text-2xl font-bold tracking-tighter">LOGISTICS</span>
        <span class="text-2xl font-bold tracking-tighter">RETAIL GROUPS</span>
        <span class="text-2xl font-bold tracking-tighter">FMCG</span>
      </div>
    </div>
  </section>
  
<!-- ── Globe ─────────────────────────────────────────────────────────────── -->
  <section id="globe-section" class="py-24 relative overflow-hidden">
    <div class="max-w-7xl mx-auto px-4">
      <div class="text-center mb-12">
        <h2 class="text-5xl font-serif italic mb-4">
          Multi-Entity Treasury <span class="text-emerald-400">at a Glance</span>
        </h2>
        <p class="text-zinc-400 text-lg max-w-2xl mx-auto font-light">
          One consolidated view of all subsidiaries, vaults, and live FX rates —
          <span class="text-emerald-400 font-mono" id="latency-value">250ms</span>
          refresh | <span id="active-flows" class="text-emerald-400">Live</span>
          across all entities
        </p>
      </div>
      <div
        class="globe-wrapper relative rounded-3xl overflow-hidden shadow-2xl"
        style="height: 650px;"
      >
        <div id="globe-container" class="w-full h-full"></div>
        <div class="globe-glow-overlay"></div>
        <div id="notification-container" class="absolute inset-0 pointer-events-none z-30"></div>
        <div class="absolute bottom-6 left-6 z-20 flex gap-3">
          <div class="bracket-card px-4 py-2 rounded-full text-[10px] font-mono backdrop-blur-md border border-emerald-400/20">
            <span class="text-emerald-400">●</span>
            ACTIVE VAULTS: <span id="vault-counter">24</span>
          </div>
          <div class="bracket-card px-4 py-2 rounded-full text-[10px] font-mono backdrop-blur-md border border-emerald-400/20">
            <span class="text-emerald-400">⚡</span> TX TODAY: <span id="tx-counter">1,247</span>
          </div>
        </div>
        <div class="absolute top-6 right-6 z-20 bracket-card px-4 py-2 rounded-full text-[10px] font-mono backdrop-blur-md border border-emerald-400/20">
          <span class="text-emerald-400">🌍</span>
          LIVE FX PAIRS: <span id="flow-counter">12</span>
          tracked
        </div>
      </div>
    </div>
  </section>
  
<!-- ── Features Bento Grid ──────────────────────────────────────────────── -->
  <section id="features" class="py-32 px-4 max-w-7xl mx-auto">
    <div class="flex flex-col md:flex-row justify-between items-end mb-16 gap-8">
      <div class="max-w-2xl">
        <h2 class="text-5xl font-serif italic mb-6">
          Built for the <span class="text-emerald-400">Finance Function.</span>
        </h2>
        <p class="text-zinc-400 text-lg font-light">
          Every module in Equinox is architected for the auditability, compliance, and real-time visibility that institutional treasury teams demand.
        </p>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-12 gap-5 auto-rows-[320px]">
      
<!-- Event-Sourced Ledger (large) -->
      <div class="md:col-span-8 elite-card p-10 rounded-3xl flex flex-col md:flex-row justify-between items-center group cursor-pointer">
        <div class="max-w-md z-10">
          <div class="flex items-center gap-3 mb-6">
            <i data-lucide="database" class="w-4 h-4 text-emerald-400"></i>
            <span class="font-mono text-[9px] text-zinc-600 tracking-[0.4em] uppercase">
              Immutable Ledger
            </span>
          </div>
          <h3 class="text-4xl font-serif italic mb-6">Complete Audit Trail</h3>
          <p class="text-zinc-500 text-sm font-light leading-relaxed mb-6">
            Every transfer, invoice match, role change, and policy decision is permanently recorded and replayable. Nothing is ever deleted. Everything is provable.
          </p>
          <div class="flex gap-4">
            <span class="px-3 py-1 border border-white/5 rounded font-mono text-[8px] text-zinc-500 uppercase">
              Event-Sourced
            </span>
            <span class="px-3 py-1 border border-white/5 rounded font-mono text-[8px] text-zinc-500 uppercase">
              Replay-on-Demand
            </span>
          </div>
        </div>
        <div class="relative w-72 h-72 flex items-center justify-center">
          <svg
            viewBox="0 0 240 240"
            class="w-full h-full transform transition-all duration-700 group-hover:scale-110"
          >
            <circle cx="120" cy="120" r="100" class="tech-path" stroke-dasharray="4 8" />
            <circle cx="120" cy="120" r="85" class="tech-path" stroke-opacity="0.3" />
            <path
              class="tech-path tech-path-primary"
              d="M160 120 C160 60, 80 60, 80 120 C80 180, 160 180, 160 120"
            />
            <path
              class="tech-path tech-path-primary"
              d="M120 80 C140 80, 175 100, 175 135 C175 170, 140 185, 120 185"
            />
            <path class="tech-path tech-path-primary" d="M175 135 L210 135" />
            <circle cx="150" cy="105" r="2.5" class="node-pulse" />
            <line x1="120" y1="20" x2="120" y2="220" class="tech-path" stroke-opacity="0.1" />
          </svg>
        </div>
      </div>
      
<!-- Biometric Auth -->
      <div class="md:col-span-4 elite-card p-10 rounded-3xl group flex flex-col justify-between">
        <div>
          <div class="flex items-center gap-3 mb-4">
            <i data-lucide="fingerprint" class="w-4 h-4 text-emerald-400"></i>
            <span class="font-mono text-[9px] text-zinc-600 tracking-[0.4em] uppercase">
              Identity
            </span>
          </div>
          <h3 class="text-2xl font-serif italic mb-4">Biometric Auth</h3>
          <p class="text-zinc-500 text-xs font-light">
            WebAuthn fingerprint authentication. Step-up verification required for high-value transfers. No passwords. No shared credentials.
          </p>
        </div>
        <div class="relative flex flex-col gap-2 mt-8 mask-fade-bottom overflow-hidden">
          <div class="h-10 border border-white/5 rounded-lg bg-zinc-950/80 flex items-center px-4 font-mono text-[8px] text-zinc-600 transition-all group-hover:border-emerald-500/30 group-hover:text-emerald-400">
            cfo@meridian-group.com ●●●●
          </div>
          <div class="h-10 border border-white/5 rounded-lg bg-zinc-950/80 flex items-center px-4 font-mono text-[8px] text-zinc-600">
            treasury.lead@vantage.io ●●●●
          </div>
          <div class="h-10 border border-white/5 rounded-lg bg-zinc-950/80 flex items-center px-4 font-mono text-[8px] text-zinc-800">
            approver@atlas-group.ch ●●●●
          </div>
        </div>
      </div>
      
<!-- Liquidity Forecasting -->
      <div class="md:col-span-4 elite-card p-10 rounded-3xl group flex flex-col items-center text-center">
        <div class="w-full flex justify-between items-start mb-4">
          <i data-lucide="trending-up" class="w-4 h-4 text-emerald-400"></i>
          <span class="font-mono text-[8px] text-zinc-700 uppercase tracking-widest">
            Forecasting
          </span>
        </div>
        <h3 class="text-2xl font-serif italic mb-3">30-Day Liquidity View</h3>
        <p class="text-zinc-500 text-xs font-light mb-8 max-w-[200px]">
          ML-powered cash flow predictions built from your historical invoices and bank statements.
        </p>
        <div class="relative w-full flex-1 flex items-center justify-center">
          <svg viewBox="0 0 200 200" class="w-48 h-48">
            <circle cx="100" cy="100" r="85" class="tech-path" stroke-opacity="0.1" />
            <circle
              cx="100"
              cy="100"
              r="85"
              class="tech-path tech-path-primary"
              stroke-dasharray="2 12"
            />
            <polyline
              points="20,140 50,100 80,120 110,70 140,85 170,50"
              class="tech-path tech-path-primary"
              style="stroke-dasharray: 300;"
            />
            <circle cx="100" cy="100" r="4" class="node-pulse" />
          </svg>
          <div class="absolute bottom-2 font-mono text-[9px] text-emerald-400 opacity-0 group-hover:opacity-100 transition-opacity uppercase tracking-widest">
            Forecast Engine Active
          </div>
        </div>
      </div>
      
<!-- Live FX Rates -->
      <div class="md:col-span-4 elite-card p-10 rounded-3xl group flex flex-col">
        <div class="flex items-center gap-3 mb-4">
          <i data-lucide="activity" class="w-4 h-4 text-emerald-400"></i>
          <span class="font-mono text-[9px] text-zinc-600 tracking-[0.4em] uppercase">
            Markets
          </span>
        </div>
        <h3 class="text-2xl font-serif italic mb-4">Live FX Rates</h3>
        <p class="text-zinc-500 text-xs font-light mb-8">
          Sub-second currency pair data via WebSocket market feeds. EUR/USD, GBP/USD, and majors — always current.
        </p>
        <div class="flex-1 relative bg-zinc-950/50 rounded-2xl border border-white/5 overflow-hidden p-4">
          <div class="flex justify-between items-center mb-3">
            <span class="font-mono text-[9px] text-zinc-500">EUR/USD</span>
            <span class="font-mono text-[9px] text-emerald-400" id="fx-eurusd">1.0847</span>
          </div>
          <div class="flex justify-between items-center mb-3">
            <span class="font-mono text-[9px] text-zinc-500">GBP/USD</span>
            <span class="font-mono text-[9px] text-emerald-400" id="fx-gbpusd">1.2634</span>
          </div>
          <div class="flex justify-between items-center">
            <span class="font-mono text-[9px] text-zinc-500">USD/JPY</span>
            <span class="font-mono text-[9px] text-emerald-400" id="fx-usdjpy">149.82</span>
          </div>
          <div class="absolute bottom-2 right-3 font-mono text-[7px] text-zinc-700 uppercase">
            Live · Polygon.io
          </div>
        </div>
      </div>
      
<!-- Anomaly Detection -->
      <div class="md:col-span-4 elite-card p-10 rounded-3xl group flex flex-col">
        <div class="flex items-center gap-3 mb-4">
          <i data-lucide="shield-alert" class="w-4 h-4 text-emerald-400"></i>
          <span class="font-mono text-[9px] text-zinc-600 tracking-[0.4em] uppercase">
            Intelligence
          </span>
        </div>
        <h3 class="text-2xl font-serif italic mb-4">Anomaly Detection</h3>
        <p class="text-zinc-500 text-xs font-light mb-6">
          Statistical Z-score analysis flags unusual invoices and transfers. BERT sentiment scoring surfaces high-risk vendor communications.
        </p>
        <div class="flex-1 relative flex items-center justify-center">
          <svg viewBox="0 0 200 200" class="w-40 h-40">
            <rect x="60" y="60" width="80" height="80" class="tech-path" />
            <rect
              x="75"
              y="45"
              width="80"
              height="80"
              class="tech-path tech-path-primary"
              stroke-opacity="0.5"
            />
            <line x1="60" y1="60" x2="75" y2="45" class="tech-path" />
            <line x1="140" y1="60" x2="155" y2="45" class="tech-path" />
            <line x1="60" y1="140" x2="75" y2="125" class="tech-path" />
            <line x1="140" y1="140" x2="155" y2="125" class="tech-path" />
            <circle cx="100" cy="100" r="2" fill="#34d399" />
            <circle cx="80" cy="80" r="1.5" fill="#34d399" style="opacity:0.4;" />
            <circle cx="130" cy="120" r="1.5" fill="#34d399" style="opacity:0.4;" />
          </svg>
        </div>
      </div>
    </div>
  </section>
  
<!-- ── How It Works ──────────────────────────────────────────────────────── -->
  <section id="technology" class="py-32 px-4 max-w-4xl mx-auto">
    <h2 class="text-5xl font-serif italic mb-16 text-center">
      How It <span class="text-emerald-400">Works</span>
    </h2>
    <div class="space-y-4">
      <div class="accordion-item border border-white/10 rounded-2xl overflow-hidden glass-card">
        <button class="accordion-trigger w-full flex justify-between items-center p-6 text-left font-bold text-lg hover:bg-white/5 transition-colors">
          <span>🔐 Biometric Transfer Authorization</span>
          <span class="accordion-icon transition-transform duration-300 text-emerald-400">+</span>
        </button>
        <div class="accordion-content">
          <div class="p-6 pt-0 border-t border-white/5 mt-2">
            <p class="text-zinc-400 text-sm font-light mb-4 leading-relaxed">
              Transfers below your configured threshold are auto-approved. High-value transfers pause for biometric step-up verification from a designated approver — enforced at the aggregate level, not just the UI.
            </p>
            <pre class="font-mono text-xs bg-black/50 p-4 rounded-lg overflow-x-auto"><span class="text-emerald-400">$</span> equinox transfer --amount 2_400_000 --currency EUR
<span class="text-zinc-500">✓ Threshold $1,000,000 exceeded — approval required
✓ Step-up challenge issued to approver@group.io
✓ Biometric verified (WebAuthn / FIDO2)
✓ VaultDebited → VaultCredited — immutable event recorded</span></pre>
          </div>
        </div>
      </div>

      <div class="accordion-item border border-white/10 rounded-2xl overflow-hidden glass-card">
        <button class="accordion-trigger w-full flex justify-between items-center p-6 text-left font-bold text-lg hover:bg-white/5 transition-colors">
          <span>⚡ Cross-Subsidiary Netting Engine</span>
          <span class="accordion-icon transition-transform duration-300 text-emerald-400">+</span>
        </button>
        <div class="accordion-content">
          <div class="p-6 pt-0 border-t border-white/5 mt-2">
            <p class="text-zinc-400 text-sm font-light mb-4 leading-relaxed">
              Before any external settlement, Equinox offsets intercompany invoices within the same netting cycle. Only the net balance moves — reducing FX conversion costs across your subsidiary network.
            </p>
            <div class="grid md:grid-cols-2 gap-4">
              <div class="bg-white/5 p-4 rounded-lg">
                <div class="text-emerald-400 font-mono text-xs mb-1">NETTING REDUCTION</div>
                <div class="text-2xl font-bold">Up to 70%</div>
                <div class="text-zinc-500 text-xs mt-1">fewer external transfers</div>
              </div>
              <div class="bg-white/5 p-4 rounded-lg">
                <div class="text-emerald-400 font-mono text-xs mb-1">CYCLE FREQUENCY</div>
                <div class="text-2xl font-bold">Configurable</div>
                <div class="text-zinc-500 text-xs mt-1">daily / weekly / monthly</div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="accordion-item border border-white/10 rounded-2xl overflow-hidden glass-card">
        <button class="accordion-trigger w-full flex justify-between items-center p-6 text-left font-bold text-lg hover:bg-white/5 transition-colors">
          <span>📊 6-Metric Compliance Control Suite</span>
          <span class="accordion-icon transition-transform duration-300 text-emerald-400">+</span>
        </button>
        <div class="accordion-content">
          <div class="p-6 pt-0 border-t border-white/5 mt-2">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
