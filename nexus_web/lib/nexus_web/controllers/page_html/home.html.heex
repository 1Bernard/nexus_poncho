      <span class="w-1.5 h-1.5 bg-emerald-400 rounded-full animate-pulse shadow-[0_0_8px_#34d399]">
      </span>
      <span class="font-mono text-[9px] text-zinc-600 uppercase tracking-widest">
        All Systems Operational
      </span>
